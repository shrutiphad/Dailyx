# ---------- shared ----------
# Postgres (local docker-compose defaults shown)
DATABASE_URL="postgresql://dailyx:dailyx@localhost:5432/dailyx?schema=public"
# Redis for BullMQ
REDIS_URL="redis://localhost:6379"

# ---------- api / worker ----------
API_PORT=4000
# Any long random string. Sessions are signed with this.
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
# Where the browser app lives — used for CORS + tracking-link origins
WEB_ORIGIN="http://localhost:3000"
# Public URL the email provider can reach for webhooks (use an ngrok URL in dev)
API_PUBLIC_URL="http://localhost:4000"

# ---------- Mailgun ----------
# Sandbox domain works out of the box (sandboxXXXX.mailgun.org)
MAILGUN_API_KEY="key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
MAILGUN_DOMAIN="sandboxXXXXXXXX.mailgun.org"
# US default; set to "https://api.eu.mailgun.net" for EU region keys
MAILGUN_BASE_URL="https://api.mailgun.net"
MAILGUN_FROM="DailyX <postmaster@sandboxXXXXXXXX.mailgun.org>"
# Mailgun signs webhooks with your HTTP webhook signing key (Settings → Webhooks)
MAILGUN_WEBHOOK_SIGNING_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ---------- web (Next.js) ----------
# Base URL of the Express API the browser talks to
NEXT_PUBLIC_API_URL="http://localhost:4000"
